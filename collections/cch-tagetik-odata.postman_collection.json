      "item": [
        {
          "id": "b7ee9d4f-94f5-407c-bae4-62c34f82ce77",
          "name": "Query Financial Data",
          "request": {
            "name": "Query Financial Data",
            "description": {
              "content": "Query financial or analytical data from a CCH Tagetik entity set using OData v4 query options including $filter, $select, $top, $skip, $orderby, and $expand.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "odata",
                ":database",
                ":entity"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "$filter",
                  "value": "<string>",
                  "description": "OData filter expression (e.g., Year eq 2025 and Period eq 'Q1')"
                },
                {
                  "disabled": false,
                  "key": "$select",
                  "value": "<string>",
                  "description": "Comma-separated list of properties to include"
                },
                {
                  "disabled": false,
                  "key": "$top",
                  "value": "<integer>",
                  "description": "Maximum number of rows to return"
                },
                {
                  "disabled": false,
                  "key": "$skip",
                  "value": "<integer>",
                  "description": "Number of rows to skip (for pagination)"
                },
                {
                  "disabled": false,
                  "key": "$orderby",
                  "value": "<string>",
                  "description": "Property name and direction for sorting (e.g., Year desc)"
                },
                {
                  "disabled": false,
                  "key": "$count",
                  "value": "<boolean>",
                  "description": "Include total count of matching records"
                },
                {
                  "disabled": false,
                  "key": "$format",
                  "value": "<string>",
                  "description": "Response format (default json)"
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "database",
                  "description": "(Required) The CCH Tagetik database code"
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "entity",
                  "description": "(Required) The entity set name (e.g., FinancialData, ConsolidationData, AnalyticalData)"
                },
                {
                  "description": "Your CCH Tagetik environment hostname",
                  "type": "any",
                  "value": "{{environment}}",
                  "key": "environment"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
